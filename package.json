{
  "name": "pklku-monorepo",
  "private": true,
  "scripts": {
    "dev:api": "pnpm --filter api run start:dev",
    "dev:web": "pnpm --filter web run dev",
    "build:api": "pnpm --filter api run build",
    "build:web": "pnpm --filter web run build",
    "build:types": "pnpm --filter shared-types run build",
    "db:generate": "pnpm --filter api run prisma generate",
    "db:migrate": "pnpm --filter api run prisma migrate dev",
    "db:seed": "pnpm --filter api run prisma db seed",
    "db:studio": "pnpm --filter api run prisma studio"
  }
}
